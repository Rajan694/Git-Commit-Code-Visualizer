{
  "name": "where-was-i",
  "displayName": "Where Was I?",
  "description": "Visualizes the latest git commit code changes via soft background gradients.",
  "icon": "assets/extension_icon.ico",
  "publisher": "Rajan694",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rajan694/Git-Commit-Code-Visualizer.git"
  },
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "whereWasI.showMenu",
        "title": "Where Was I: Settings Menu"
      },
      {
        "command": "whereWasI.toggleHighlights",
        "title": "Where Was I: Toggle Highlights"
      }
    ],
    "keybindings": [
      {
        "command": "whereWasI.toggleHighlights",
        "key": "ctrl+alt+w",
        "mac": "ctrl+alt+w"
      }
    ],
    "configuration": {
      "title": "Where Was I?",
      "properties": {
        "whereWasI.showDiffChanges": {
          "type": "boolean",
          "default": true,
          "description": "Toggle highlighting of recent git changes."
        },
        "whereWasI.diffColor": {
          "type": "string",
          "default": "#3f79c5",
          "enum": [
            "#3f79c5",
            "#4caf50",
            "#ff9800",
            "#e91e63",
            "#9c27b0"
          ],
          "enumDescriptions": [
            "Ocean Blue",
            "Mint Green",
            "Amber",
            "Rose",
            "Violet"
          ],
          "description": "Choose a preset color for the highlight."
        },
        "whereWasI.showYours": {
          "type": "boolean",
          "default": false,
          "description": "If true, only highlight lines if you are the author of the latest commit for the file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.0",
    "@types/vscode": "^1.102.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3"
  }
}
